# Fichiers de configuration sensibles
# NB : backend/config.php n'est PAS ignoré : il ne contient plus aucun
# secret en dur (tout passe par variables d'environnement, voir le fichier).
.env
.env.local
.env.production

# Base de données
*.db
*.sqlite
*.sqlite3
database.sqlite

# Fichiers joints uploadés par les clients (demandes de devis)
database/uploads/

# Sauvegardes automatiques de la base (voir backend/backup.php)
database/backups/

# Logs
*.log
logs/
error.log
access.log

# Fichiers temporaires
*.tmp
*.temp
temp/
tmp/

# Cache
cache/
*.cache

# Sessions PHP
sessions/

# Fichiers de sauvegarde
*.bak
*.backup
*.old

# Fichiers système
.DS_Store
Thumbs.db
desktop.ini

# IDE/Editeurs
.vscode/
.idea/
*.swp
*.swo
*~

# Node.js (outillage de test E2E, voir tests/ et playwright.config.js)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Rapports Playwright
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Composer (si vous l'utilisez)
vendor/
composer.lock

# Fichiers de déploiement
deploy.sh
*.zip
*.tar.gz

# Fichiers de test
test-*.php
debug-*.php

# Fichiers de configuration local
config-local.php
config-dev.php
